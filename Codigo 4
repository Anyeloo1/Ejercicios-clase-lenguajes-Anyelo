using System;

class Program
{
    static void Main()
    {
        int vacunasDia;
        int totalVacunas = 0;
        double promedio;

        string[] dias = { "Lunes", "Martes", "Miercoles", "Jueves", "Viernes", "Sabado", "Domingo" };

        // Ciclo for 
        for (int i = 0; i < dias.Length; i++)
        {
            Console.Write("Ingrese la cantidad de vacunas aplicadas el " + dias[i] + ": ");
            vacunasDia = Convert.ToInt32(Console.ReadLine());

            totalVacunas += vacunasDia; // acumulador
        }

        // cálculo del promedio
        promedio = (double)totalVacunas / dias.Length;

        // reporte final
        Console.WriteLine("\n=== REPORTE SEMANAL DE VACUNACION ===");
        Console.WriteLine("Total de vacunas aplicadas en la semana: " + totalVacunas);
        Console.WriteLine("Promedio diario de vacunas: " + promedio);

        Console.WriteLine("\nFin del reporte.");
        Console.ReadKey();
    }
}
